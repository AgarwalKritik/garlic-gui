<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bundle identity -->
    <key>CFBundleIdentifier</key>
    <string>@MACOSX_BUNDLE_GUI_IDENTIFIER@</string>

    <key>CFBundleName</key>
    <string>@MACOSX_BUNDLE_BUNDLE_NAME@</string>

    <key>CFBundleDisplayName</key>
    <string>Garlic Decompiler</string>

    <key>CFBundleExecutable</key>
    <string>@MACOSX_BUNDLE_EXECUTABLE_NAME@</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleSignature</key>
    <string>????</string>

    <!-- Version -->
    <key>CFBundleVersion</key>
    <string>@MACOSX_BUNDLE_BUNDLE_VERSION@</string>

    <key>CFBundleShortVersionString</key>
    <string>@MACOSX_BUNDLE_SHORT_VERSION_STRING@</string>

    <!-- Icon -->
    <key>CFBundleIconFile</key>
    <string>garlic.icns</string>

    <!-- Retina / HiDPI support — required for crisp rendering on Retina displays -->
    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- Minimum macOS version (matches CMAKE_OSX_DEPLOYMENT_TARGET) -->
    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>

    <!-- Allow running from the command line without a GUI dock bounce -->
    <key>LSUIElement</key>
    <false/>

    <!-- Dark mode support — inherit from system appearance -->
    <key>NSRequiresAquaSystemAppearance</key>
    <false/>

    <!-- Document types: associate APK, DEX, JAR, CLASS files with this app -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Android Package</string>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>apk</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
        </dict>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Dalvik Executable</string>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>dex</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
        </dict>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Java Archive</string>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>jar</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
        </dict>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Java Class File</string>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>class</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
        </dict>
    </array>

    <!-- Copyright string -->
    <key>NSHumanReadableCopyright</key>
    <string>Copyright 2026 Kritik Agarwal. All rights reserved.</string>
</dict>
</plist>
